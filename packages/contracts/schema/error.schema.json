{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clip-factory.local/contracts/ErrorEnvelope/1.0.0",
  "title": "ErrorEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "error"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "category",
        "retryable",
        "message",
        "requiredAction",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": ["RETRYABLE", "NON_RETRYABLE", "WAITING", "CANCELLED"]
        },
        "retryable": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "requiredAction": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
