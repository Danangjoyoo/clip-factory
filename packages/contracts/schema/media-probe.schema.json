{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clip-factory.local/contracts/MediaProbe/1.0.0",
  "title": "MediaProbe",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "durationMs",
    "sizeBytes",
    "container",
    "video",
    "audio",
    "formatTags"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 1
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 1
    },
    "container": {
      "enum": ["mp4", "mov", "matroska", "webm"]
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codec",
        "width",
        "height",
        "frameRateNumerator",
        "frameRateDenominator"
      ],
      "properties": {
        "codec": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "frameRateNumerator": {
          "type": "integer",
          "minimum": 1
        },
        "frameRateDenominator": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codec", "sampleRateHz", "channels"],
      "properties": {
        "codec": {
          "type": "string",
          "minLength": 1
        },
        "sampleRateHz": {
          "type": "integer",
          "minimum": 1
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "formatTags": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
